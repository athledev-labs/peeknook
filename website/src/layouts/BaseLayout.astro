---
// SPDX-License-Identifier: Apache-2.0
import "../styles/global.css";
import ChromeLink from "../components/ChromeLink.astro";
import SiteNav from "../components/SiteNav.astro";
import { getRelease } from "../lib/release";

const release = await getRelease();

interface Props {
  title: string;
  description?: string;
  current?: "home" | "privacy" | "licenses" | "docs" | "features" | "roadmap";
  centerMain?: boolean;
}

const {
  title,
  description = "Complete AI for Mac. Every surface. Private AI you customize.",
  current,
  centerMain = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const hasRail = Astro.slots.has("rail");
const isHome = current === "home";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#e8e8ee" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&display=swap"
      rel="stylesheet"
    />
    <title>{title} · Peeknook</title>
    <link
      rel="icon"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
      type="image/svg+xml"
    />
  </head>
  <body>
    <div class="theme-backdrop" aria-hidden="true"></div>
    <div class="shell">
      <header class="topbar">
        <div class="page-grid page-grid--chrome">
          <a class="brand" href={import.meta.env.BASE_URL}>
            <img
              class="brand-mark"
              src={`${import.meta.env.BASE_URL}logo-mark.svg`}
              alt=""
              width="18"
              height="18"
              decoding="async"
            />
            <span>Peeknook</span>
          </a>
          <SiteNav
            base={base}
            current={current}
            releasesURL={release.latestReleasesURL}
          />
        </div>
      </header>

      <main
        class:list={[
          "page-main",
          centerMain && "page-main--center",
          isHome && "page-main--home",
        ]}
      >
        {
          isHome ? (
            <div class="page-grid page-grid--home">
              <slot />
            </div>
          ) : (
            <div class="page-grid">
              <div class="page-content">
                <slot />
              </div>
              {hasRail && (
                <aside class="page-rail" aria-label="Page sections">
                  <slot name="rail" />
                </aside>
              )}
            </div>
          )
        }
      </main>

      <footer class="footbar">
        <div class="page-grid page-grid--chrome">
          <span class="footbar-version">v{release.version}</span>
          <div class="footbar-links">
            <ChromeLink
              href={`${base}privacy/`}
              icon="privacy"
              current={current === "privacy"}
            >
              Privacy
            </ChromeLink>
            <ChromeLink
              href={`${base}licenses/`}
              icon="licenses"
              current={current === "licenses"}
            >
              Licenses
            </ChromeLink>
            <ChromeLink
              href="https://github.com/glendonC/peeknook/issues"
              icon="issues"
              external
            >
              Issues
            </ChromeLink>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
