---
// SPDX-License-Identifier: Apache-2.0
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import { getRelease } from "../lib/release";
import { SITE_ORIGIN, sitePath, type SiteCurrent } from "../lib/sitePages";

const release = await getRelease();
const base = import.meta.env.BASE_URL;

interface Props {
  title: string;
  description?: string;
  current?: SiteCurrent;
  centerMain?: boolean;
  noIndex?: boolean;
}

const {
  title,
  description = "Complete AI for Mac. Every surface. Private AI you customize.",
  current,
  centerMain = false,
  noIndex = false,
} = Astro.props;

const isHome = current === "home";
const pageTitle = `${title} · Peeknook`;
const canonicalPath =
  current === "home" || !current ? sitePath(base) : sitePath(base, `${current}/`);
const canonicalURL = new URL(canonicalPath, SITE_ORIGIN).href;
const ogImage = new URL(sitePath(base, "logo-mark.svg"), SITE_ORIGIN).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#e8e8ee" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Peeknook" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <title>{pageTitle}</title>
    <link
      rel="icon"
      href={sitePath(base, "favicon.svg")}
      type="image/svg+xml"
    />
    <link rel="apple-touch-icon" href={sitePath(base, "logo-mark.svg")} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="theme-backdrop" aria-hidden="true"></div>
    <div class="shell">
      <header class="topbar">
        <div class="page-grid page-grid--chrome">
          <a class="brand" href={sitePath(base)}>
            <img
              class="brand-mark"
              src={sitePath(base, "logo-mark.svg")}
              alt=""
              width="18"
              height="18"
              decoding="async"
            />
            <span>Peeknook</span>
          </a>
          <SiteNav
            base={base}
            current={current}
            releasesURL={release.latestReleasesURL}
          />
        </div>
      </header>

      <main
        id="main-content"
        tabindex="-1"
        class:list={[
          "page-main",
          centerMain && "page-main--center",
          isHome && "page-main--home",
          !isHome && "page-main--doc",
        ]}
      >
        <div class="page-grid page-grid--home">
          <slot />
        </div>
      </main>

      <SiteFooter base={base} version={release.version} current={current} />
    </div>
  </body>
</html>
