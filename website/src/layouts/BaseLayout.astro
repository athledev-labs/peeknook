---
// SPDX-License-Identifier: Apache-2.0
import "../styles/global.css";
import { getRelease } from "../lib/release";

const release = await getRelease();

interface Props {
  title: string;
  description?: string;
  current?: "home" | "privacy" | "licenses";
  centerMain?: boolean;
}

const {
  title,
  description = "Context in the MacBook notch.",
  current,
  centerMain = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const hasRail = Astro.slots.has("rail");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&display=swap"
      rel="stylesheet"
    />
    <title>{title} · Peeknook</title>
    <link
      rel="icon"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
      type="image/svg+xml"
    />
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <div class="page-grid">
          <a class="brand" href={import.meta.env.BASE_URL}>
            <img
              class="brand-mark"
              src={`${import.meta.env.BASE_URL}logo-mark.svg`}
              alt=""
              width="18"
              height="18"
              decoding="async"
            />
            <span>Peeknook</span>
          </a>
          <nav class="nav" aria-label="Primary">
            <a href="https://github.com/glendonC/peeknook">GitHub</a>
          </nav>
        </div>
      </header>

      <main class:list={["page-main", centerMain && "page-main--center"]}>
        <div class="page-grid">
          <div class="page-content">
            <slot />
          </div>
          {
            hasRail && (
              <aside class="page-rail" aria-label="Page sections">
                <slot name="rail" />
              </aside>
            )
          }
        </div>
      </main>

      <footer class="footbar">
        <div class="page-grid">
          <span class="footbar-version">v{release.version}</span>
          <div class="footbar-links">
            <a
              href={`${base}privacy/`}
              aria-current={current === "privacy" ? "page" : undefined}
            >
              Privacy
            </a>
            <a
              href={`${base}licenses/`}
              aria-current={current === "licenses" ? "page" : undefined}
            >
              Licenses
            </a>
            <a href="https://github.com/glendonC/peeknook/issues">Issues</a>
            <a href={release.latestReleasesURL}>Releases</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
