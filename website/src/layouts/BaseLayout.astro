---
// SPDX-License-Identifier: Apache-2.0
import "../styles/global.css";
import FixedDownloadDock from "../components/FixedDownloadDock.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import { getRelease } from "../lib/release";

const release = await getRelease();

interface Props {
  title: string;
  description?: string;
  current?: "home" | "privacy" | "licenses" | "docs" | "features";
  centerMain?: boolean;
  fixedDownloadURL?: string;
}

const {
  title,
  description = "Complete AI for Mac. Every surface. Private AI you customize.",
  current,
  centerMain = false,
  fixedDownloadURL,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const isHome = current === "home";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#e8e8ee" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&display=swap"
      rel="stylesheet"
    />
    <title>{title} · Peeknook</title>
    <link
      rel="icon"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
      type="image/svg+xml"
    />
  </head>
  <body class:list={fixedDownloadURL && "has-download-dock"}>
    <div class="theme-backdrop" aria-hidden="true"></div>
    <div class="shell">
      <header class="topbar">
        <div class="page-grid page-grid--chrome">
          <a class="brand" href={import.meta.env.BASE_URL}>
            <img
              class="brand-mark"
              src={`${import.meta.env.BASE_URL}logo-mark.svg`}
              alt=""
              width="18"
              height="18"
              decoding="async"
            />
            <span>Peeknook</span>
          </a>
          <SiteNav
            base={base}
            current={current}
            releasesURL={release.latestReleasesURL}
          />
        </div>
      </header>

      <main
        class:list={[
          "page-main",
          centerMain && "page-main--center",
          isHome && "page-main--home",
          !isHome && "page-main--doc",
          fixedDownloadURL && "page-main--dock",
        ]}
      >
        <div class="page-grid page-grid--home">
          <slot />
        </div>
      </main>

      <SiteFooter base={base} version={release.version} current={current} />
    </div>
    {fixedDownloadURL && <FixedDownloadDock href={fixedDownloadURL} />}
  </body>
</html>
