---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../layouts/BaseLayout.astro";
import { sitePath } from "../lib/sitePages";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Not found"
  description="This page does not exist."
  centerMain
  noIndex
>
  <section class="home-hero not-found">
    <div class="home-hero-copy">
      <p class="not-found-code" aria-hidden="true">404</p>
      <h1>Page not found</h1>
      <p class="home-hero-tagline">That link is broken or the page moved.</p>
    </div>
    <div class="home-actions">
      <a class="not-found-link" href={sitePath(base)}>Home</a>
      <a class="not-found-link not-found-link--muted" href={sitePath(base, "docs/")}>Docs</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found-code {
    margin: 0 0 0.35rem;
    font-size: 0.6875rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .not-found-link {
    font-size: 0.8125rem;
    font-weight: var(--weight-medium);
    border-bottom: 0.5px solid var(--line);
  }

  .not-found-link--muted {
    font-weight: var(--weight-regular);
    color: var(--text-muted);
  }

  .not-found-link:hover {
    border-color: rgba(0, 0, 0, 0.32);
  }
</style>
