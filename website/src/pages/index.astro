---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../layouts/BaseLayout.astro";
import DownloadCTA from "../components/DownloadCTA.astro";
import { getRelease } from "../lib/release";

const release = await getRelease();
---

<BaseLayout
  title="Peeknook"
  description="Complete AI for Mac, in the notch. Every surface. AI you customize."
  current="home"
>
  <section class="home-hero">
    <div class="home-hero-copy">
      <h1>Complete AI for Mac, in the notch</h1>
      <p class="home-hero-tagline">Every surface. AI you customize.</p>
    </div>
    <div class="home-actions">
      <DownloadCTA href={release.dmgURL} />
    </div>
    <figure class="home-demo">
      <div class="demo-squircle">
        {/* Light gradient stand-in until the product capture is recorded —
            swap .demo-gradient for
            <video class="demo-media" autoplay muted loop playsinline …>. */}
        <span class="demo-notch" aria-hidden="true"></span>
        <span class="demo-gradient" aria-hidden="true"></span>
      </div>
    </figure>
  </section>
</BaseLayout>
