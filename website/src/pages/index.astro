---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../layouts/BaseLayout.astro";
import DemoFrame from "../components/DemoFrame.astro";
import { release } from "../data/release";
---

<BaseLayout
  title="Peeknook"
  description="Local-first practice copilot in the MacBook notch."
  current="home"
  viewport={true}
>
  <section class="home-stage">
    <div class="home-copy">
      <p class="kicker">macOS · local only</p>
      <h1>Practice in the notch.</h1>
      <p class="tagline">
        Capture with ⌘⇧P. Answers stay on your Mac.
      </p>
      <div class="home-actions">
        <a class="btn-download" href={release.dmgURL}>Download for Mac</a>
        <a class="link-quiet" href={release.latestReleasesURL}>GitHub</a>
      </div>
    </div>

    <DemoFrame />
  </section>
</BaseLayout>
