---
// SPDX-License-Identifier: Apache-2.0
import DocsLayout from "../../components/DocsLayout.astro";
import { formatReleaseDate, getChangelog } from "../../lib/changelog";
import { getRelease } from "../../lib/release";
import { sitePath } from "../../lib/sitePages";

const release = await getRelease();
const entries = (await getChangelog()).map((entry) => ({
  ...entry,
  anchor: `v${entry.version.replace(/[^a-z0-9]+/gi, "-")}`,
}));
const base = import.meta.env.BASE_URL;
const toc = entries.map((entry) => ({ id: entry.anchor, title: entry.version }));
---

<DocsLayout
  title="Changelog"
  tagline="Release history for the signed macOS app. Newest first."
  description="Peeknook release notes. Version history and highlights."
  current="changelog"
  toc={toc}
>
  <div class="changelog-list">
    {
      entries.map((entry) => (
        <article class="changelog-entry" id={entry.anchor}>
          <header class="changelog-header">
            <h2 class="changelog-version">
              <a href={entry.url}>{entry.version}</a>
            </h2>
            <time class="changelog-date" datetime={entry.publishedAt}>
              {formatReleaseDate(entry.publishedAt)}
            </time>
          </header>
          <div class="prose changelog-body" set:html={entry.bodyHtml} />
        </article>
      ))
    }
  </div>

  <p class="doc-note changelog-foot">
    All builds: <a href={release.latestReleasesURL}>GitHub Releases</a>
    · Install: <a href={sitePath(base, "docs/")}>Docs</a>
  </p>
</DocsLayout>

<style>
  .changelog-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .changelog-entry {
    padding: 1.85rem 0;
    border-top: 0.5px solid var(--line-soft);
  }

  .changelog-entry:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .changelog-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-bottom: 0.85rem;
  }

  .changelog-version {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    font-weight: var(--weight-regular);
    letter-spacing: -0.02em;
  }

  .changelog-version a {
    color: inherit;
    border-bottom: 0.5px solid var(--line);
  }

  .changelog-version a:hover {
    border-color: rgba(0, 0, 0, 0.32);
  }

  .changelog-date {
    font-size: 0.75rem;
    font-weight: var(--weight-light);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .changelog-body :global(p:first-child) {
    margin-top: 0;
  }

  .changelog-foot {
    margin-top: 1.75rem;
  }
</style>
