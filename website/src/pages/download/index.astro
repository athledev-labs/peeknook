---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRelease } from "../../lib/release";

const release = await getRelease();
---

<BaseLayout
  title="Download"
  description="Download Peeknook for macOS — signed DMG and SHA-256 checksum."
  current="docs"
  fixedDownloadURL={release.dmgURL}
>
  <section class="home-hero">
    <div class="home-hero-copy">
      <h1>Download</h1>
      <p class="home-hero-tagline">
        Signed macOS app for Apple Silicon and Intel Macs running macOS 15+.
      </p>
    </div>
    <div class="doc-guide">
      <section class="doc-section">
        <h2 class="doc-section-title">Latest release</h2>
        <dl class="doc-rows doc-rows--spec">
          <div class="doc-row">
            <dt>Version</dt>
            <dd>{release.version}</dd>
          </div>
          <div class="doc-row">
            <dt>Requires</dt>
            <dd>macOS 15 or later</dd>
          </div>
        </dl>
        <p>
          <a class="btn-download" href={release.dmgURL}>Download Peeknook.dmg</a>
        </p>
        <p class="doc-note">
          Full install steps: <a href={`${import.meta.env.BASE_URL}docs/`}>Docs</a>
          · <a href={release.latestReleasesURL}>All releases</a>
        </p>
      </section>

      {
        release.dmgSHA256 && (
          <section class="doc-section" id="checksum">
            <h2 class="doc-section-title">SHA-256 checksum</h2>
            <p class="doc-lead">
              Compare this value after download to verify the file was not
              tampered with in transit:
            </p>
            <pre class="doc-code checksum-block">
              <code>{release.dmgSHA256}</code>
            </pre>
            <p class="doc-note">
              In Terminal: <code>shasum -a 256 ~/Downloads/Peeknook*.dmg</code>
            </p>
          </section>
        )
      }

      {
        release.zipURL && (
          <section class="doc-section">
            <h2 class="doc-section-title">ZIP (alternative)</h2>
            <p>
              <a href={release.zipURL}>Download Peeknook.zip</a> — same build,
              different packaging.
            </p>
          </section>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .checksum-block {
    word-break: break-all;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8125rem;
  }
</style>
