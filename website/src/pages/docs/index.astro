---
// SPDX-License-Identifier: Apache-2.0
import DocsPage from "../../components/DocsPage.astro";
import { renderRepoMarkdown } from "../../lib/markdown";
import { getRelease } from "../../lib/release";

const release = await getRelease();
const { html } = renderRepoMarkdown("INSTALL.md", { stripLeadingH1: true });
---

<DocsPage
  title="Docs"
  tagline="Install Peeknook and start capturing — no Terminal required."
  description="Install Peeknook on macOS, set up Ollama.app, grant permissions, and capture."
  current="docs"
  downloadURL={release.dmgURL}
>
  <article class="prose doc-guide" set:html={html} />

  <details class="doc-advanced">
    <summary>Advanced: Terminal commands</summary>
    <div class="doc-advanced-body">
      <p>
        Prefer Homebrew? Use the official <strong>cask</strong>, not the formula:
      </p>
      <pre class="doc-code"><code>brew install --cask ollama-app</code></pre>
      <p>
        Pull a model manually (Peeknook can download from Get ready instead):
      </p>
      <pre class="doc-code"><code>ollama pull gemma4:e4b</code></pre>
      <p>
        Verify a downloaded DMG checksum:
      </p>
      <pre class="doc-code"><code>shasum -a 256 ~/Downloads/Peeknook*.dmg</code></pre>
    </div>
  </details>
</DocsPage>

<style>
  .doc-advanced {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-subtle);
  }

  .doc-advanced summary {
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
    list-style: none;
  }

  .doc-advanced summary::-webkit-details-marker {
    display: none;
  }

  .doc-advanced-body {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .doc-advanced-body p {
    margin: 0.5rem 0;
  }

  .doc-code {
    margin: 0.5rem 0 1rem;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    background: var(--surface-muted);
    font-size: 0.8125rem;
    overflow-x: auto;
  }
</style>
