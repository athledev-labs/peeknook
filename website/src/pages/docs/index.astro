---
// SPDX-License-Identifier: Apache-2.0
import DocsLayout from "../../components/DocsLayout.astro";
import DocBody from "../../components/DocBody.astro";
import { parseRepoMarkdownSections } from "../../lib/markdown";
import { getRelease } from "../../lib/release";

const release = await getRelease();
const { sections } = parseRepoMarkdownSections("INSTALL.md");
const toc = sections.map((s) => ({ id: s.id, title: s.title }));
---

<DocsLayout
  title="Installation"
  tagline="Install Peeknook and start capturing. No Terminal required."
  description="Install Peeknook on macOS, set up Ollama.app, grant permissions, and capture."
  current="docs"
  toc={toc}
>
  <DocBody sections={sections} />

  <details class="doc-advanced" id="verify-checksum">
    <summary>Advanced: verify download &amp; Terminal commands</summary>
    <div class="doc-advanced-body prose">
      {
        release.dmgSHA256 && (
          <>
            <p>
              Latest release (<strong>{release.version}</strong>) DMG SHA-256:
            </p>
            <pre class="doc-code--checksum"><code>{release.dmgSHA256}</code></pre>
          </>
        )
      }
      <p>Compare after download:</p>
      <pre><code>shasum -a 256 ~/Downloads/Peeknook*.dmg</code></pre>
      <p>
        Also on <a href={release.latestReleasesURL}>GitHub Releases</a>
        {release.zipURL && (
          <>
            {" "}· <a href={release.zipURL}>Peeknook.zip</a>
          </>
        )}
      </p>
      <p>
        Prefer Homebrew? Use the official <strong>cask</strong>, not the formula:
      </p>
      <pre><code>brew install --cask ollama-app</code></pre>
      <p>Pull a model manually (Peeknook can download from Get ready instead):</p>
      <pre><code>ollama pull gemma4:e4b</code></pre>
    </div>
  </details>
</DocsLayout>
