---
// SPDX-License-Identifier: Apache-2.0
import DocsPage from "../../components/DocsPage.astro";
import { getRelease } from "../../lib/release";

const release = await getRelease();
---

<DocsPage
  title="Docs"
  tagline="Install Peeknook and start capturing."
  description="Install Peeknook on macOS, set up Ollama, grant permissions, and capture."
  current="docs"
  downloadURL={release.dmgURL}
>
  <section class="doc-section" id="get-started">
    <h2 class="doc-section-title">Get started</h2>
    <ol class="doc-steps">
      <li class="doc-step">
        <div class="doc-step-body">
          <p>
            Download the signed <code>.dmg</code> from
            <a href={release.latestReleasesURL}>Releases</a> and drag Peeknook into
            Applications.
          </p>
        </div>
      </li>
      <li class="doc-step">
        <div class="doc-step-body">
          <p>
            Install Ollama with the official app. The Homebrew
            <code>ollama</code> formula can ship without required pieces; use
            the cask instead.
          </p>
          <pre class="doc-code"><code>brew install --cask ollama-app</code></pre>
        </div>
      </li>
      <li class="doc-step">
        <div class="doc-step-body">
          <p>
            Download a vision model in Settings, or pull one in Terminal. See
            <a href="#models">Choose your model</a> below for a suggested
            starting point.
          </p>
        </div>
      </li>
      <li class="doc-step">
        <div class="doc-step-body">
          <p>
            Open Peeknook and finish <strong>Get ready</strong>: Ollama running,
            model downloaded, and Screen Recording turned on.
          </p>
        </div>
      </li>
    </ol>
    <p class="doc-note">
      Requires macOS 15+. Screen Recording is required. Accessibility is
      optional and adds selected text alongside the screenshot. When setup is
      done, press <kbd>⌘⇧P</kbd> to capture what you are looking at. Press
      <kbd>⌘⇧B</kbd> first if you want to brief Peeknook before capture.
    </p>
  </section>

  <section class="doc-section" id="models">
    <h2 class="doc-section-title">Choose your model</h2>
    <p class="doc-lead">
      Peeknook uses local Ollama at <code>http://127.0.0.1:11434</code> by
      default. Use any vision model from Settings. Suggested Gemma 4 tags by
      RAM:
    </p>
    <dl class="doc-rows doc-rows--spec">
      <div class="doc-row">
        <dt>16 GB or less</dt>
        <dd><code>gemma4:e2b</code></dd>
      </div>
      <div class="doc-row">
        <dt>17–24 GB</dt>
        <dd><code>gemma4:e4b</code></dd>
      </div>
      <div class="doc-row">
        <dt>25 GB or more</dt>
        <dd><code>gemma4:26b</code></dd>
      </div>
    </dl>
    <p class="doc-note">
      Gemma 4 is the default recommendation, not a requirement.
    </p>
  </section>
</DocsPage>
