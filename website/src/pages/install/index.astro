---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../../layouts/BaseLayout.astro";
import { release } from "../../data/release";
---

<BaseLayout
  title="Install"
  description="Install Peeknook from the release DMG."
  current="install"
>
  <h1 class="doc-title">Install</h1>
  <p class="doc-lede">Signed app only. Grant Screen Recording to Peeknook, not Terminal.</p>

  <ol class="doc-steps">
    <li>
      <h2>Download</h2>
      <p>
        <a href={release.dmgURL}>Peeknook-{release.version}.dmg</a>
      </p>
    </li>
    <li>
      <h2>Applications</h2>
      <p>Drag Peeknook into Applications and open from there.</p>
    </li>
    <li>
      <h2>Setup</h2>
      <p>
        Install <a href="https://formulae.brew.sh/cask/ollama-app">ollama-app</a>,
        pull Gemma 4, allow Screen Recording for Peeknook.
      </p>
    </li>
  </ol>

  <p class="doc-note">
    <strong>Developers:</strong> <code>swift run</code> uses a different bundle identity.
    Test the shipped app before filing permission bugs.
  </p>

  <div class="doc-actions">
    <a class="btn-download" href={release.dmgURL}>Download for Mac</a>
    <a class="link-quiet" href={import.meta.env.BASE_URL}>Home</a>
  </div>
</BaseLayout>
