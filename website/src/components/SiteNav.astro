---
// SPDX-License-Identifier: Apache-2.0
import ChromeLink from "./ChromeLink.astro";
import { sitePath, type SiteCurrent } from "../lib/sitePages";

interface Props {
  base: string;
  current?: SiteCurrent;
  releasesURL: string;
}

const { base, current, releasesURL } = Astro.props;

const links = [
  { href: sitePath(base, "features/"), icon: "features" as const, label: "Features", page: "features" },
  { href: sitePath(base, "docs/"), icon: "docs" as const, label: "Docs", page: "docs" },
  { href: sitePath(base, "faq/"), icon: "faq" as const, label: "FAQ", page: "faq" },
  { href: releasesURL, icon: "releases" as const, label: "Releases", external: true },
  { href: "https://github.com/glendonC/peeknook", icon: "github" as const, label: "GitHub", external: true },
] as const;
---

<nav class="nav nav--desktop" aria-label="Primary">
  {
    links.map((link) => (
      <ChromeLink
        href={link.href}
        icon={link.icon}
        current={"page" in link && current === link.page}
        external={"external" in link && link.external}
      >
        {link.label}
      </ChromeLink>
    ))
  }
</nav>

<button
  type="button"
  class="menu-toggle"
  aria-expanded="false"
  aria-controls="site-menu"
  aria-label="Open menu"
>
  <span class="menu-toggle-bars" aria-hidden="true">
    <span></span>
    <span></span>
  </span>
</button>

<div id="site-menu" class="mobile-menu" hidden>
  <div class="mobile-menu-backdrop" data-menu-dismiss></div>
  <div class="mobile-menu-panel">
    <nav class="mobile-menu-nav" aria-label="Primary">
      {
        links.map((link) => (
          <ChromeLink
            href={link.href}
            icon={link.icon}
            menu
            current={"page" in link && current === link.page}
            external={"external" in link && link.external}
          >
            {link.label}
          </ChromeLink>
        ))
      }
    </nav>
  </div>
</div>

<script>
  import "../scripts/mobileMenu";
</script>
