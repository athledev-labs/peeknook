---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../layouts/BaseLayout.astro";
import { renderRepoMarkdown } from "../lib/markdown";
import type { SiteCurrent } from "../lib/sitePages";

interface Props {
  title: string;
  description?: string;
  source: string;
  current: SiteCurrent;
  tagline?: string;
}

const { title, description, source, current, tagline } = Astro.props;
const { html } = renderRepoMarkdown(source, { stripLeadingH1: true });
---

<BaseLayout title={title} description={description} current={current}>
  <section class="home-hero">
    <div class="home-hero-copy">
      <h1>{title}</h1>
      {tagline && <p class="home-hero-tagline">{tagline}</p>}
    </div>
    <article class="prose doc-guide" set:html={html} />
  </section>
</BaseLayout>
