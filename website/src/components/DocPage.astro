---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../layouts/BaseLayout.astro";
import { renderRepoMarkdown } from "../lib/markdown";

interface Props {
  title: string;
  description?: string;
  source: string;
  current: "privacy" | "licenses";
}

const { title, description, source, current } = Astro.props;
const { html } = renderRepoMarkdown(source, { stripLeadingH1: true });
---

<BaseLayout title={title} description={description} current={current}>
  <section class="home-hero">
    <div class="home-hero-copy">
      <h1>{title}</h1>
      {description && <p class="home-hero-tagline">{description}</p>}
    </div>
    <article class="prose" set:html={html} />
  </section>
</BaseLayout>
