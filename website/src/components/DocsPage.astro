---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  title: string;
  tagline?: string;
  description?: string;
  current: "docs";
  downloadURL?: string;
}

const { title, tagline, description, current, downloadURL } = Astro.props;
const meta = description ?? tagline;
---

<BaseLayout
  title={title}
  description={meta}
  current={current}
  fixedDownloadURL={downloadURL}
>
  <section class="home-hero">
    <div class="home-hero-copy">
      <h1>{title}</h1>
      {tagline && <p class="home-hero-tagline">{tagline}</p>}
    </div>
    <div class="doc-guide">
      <slot />
    </div>
  </section>
</BaseLayout>
