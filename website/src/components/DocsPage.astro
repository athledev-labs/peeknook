---
// SPDX-License-Identifier: Apache-2.0
import BaseLayout from "../layouts/BaseLayout.astro";
import type { SiteCurrent } from "../lib/sitePages";

interface Props {
  title: string;
  tagline?: string;
  description?: string;
  current: SiteCurrent;
}

const { title, tagline, description, current } = Astro.props;
const meta = description ?? tagline;
---

<BaseLayout title={title} description={meta} current={current}>
  <section class="home-hero">
    <div class="home-hero-copy">
      <h1>{title}</h1>
      {tagline && <p class="home-hero-tagline">{tagline}</p>}
    </div>
    <div class="doc-guide">
      <slot />
    </div>
  </section>
</BaseLayout>
